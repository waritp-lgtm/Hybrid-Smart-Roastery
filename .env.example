# ================================================================
# Eight Coffee Roasters — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to Git!
# ================================================================

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://eight_admin:CHANGE_ME_DB_PASSWORD@localhost:5432/eight_coffee
POSTGRES_USER=eight_admin
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=eight_coffee

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT Auth ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_JWT_SECRET_MINIMUM_32_CHARACTERS
JWT_EXPIRES_IN=7d

# ── NextAuth ─────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET_MINIMUM_32_CHARACTERS

# ── LINE Messaging API ───────────────────────────────────────────
# ดูได้จาก https://developers.line.biz → Messaging API Channel
LINE_CHANNEL_ID=CHANGE_ME
LINE_CHANNEL_SECRET=CHANGE_ME
LINE_CHANNEL_ACCESS_TOKEN=CHANGE_ME
LINE_ADMIN_GROUP_ID=CHANGE_ME  # Group ID สำหรับแจ้งเตือน Admin
NEXT_PUBLIC_LIFF_ID=CHANGE_ME  # LIFF App ID

# ── Google Gemini API ────────────────────────────────────────────
# ดูได้จาก https://aistudio.google.com → Get API Key (ฟรี)
GEMINI_API_KEY=CHANGE_ME

# ── Flash Express API ────────────────────────────────────────────
# ดูได้จาก Flash Express Partner Portal
FLASH_API_KEY=CHANGE_ME
FLASH_API_URL=https://api.flashexpress.co.th
FLASH_SENDER_NAME=Eight Coffee Roasters
FLASH_SENDER_PHONE=CHANGE_ME
FLASH_SENDER_ADDRESS=CHANGE_ME

# ── GB Prime Pay (Mock mode ก่อน — เปิดเมื่อมี Account) ─────────
GBPAY_PUBLIC_KEY=mock
GBPAY_TOKEN=mock
GBPAY_API_URL=https://api.gbprimepay.com

# ── NAS Storage Paths ────────────────────────────────────────────
# Path ที่ NAS mount บน RPi 5
NAS_MEDIA_PATH=/mnt/nas/eight-coffee/media
NAS_BACKUP_PATH=/mnt/nas/eight-coffee/backup

# ── Cloudflare Tunnel ────────────────────────────────────────────
# ดูได้จาก Cloudflare Dashboard → Zero Trust → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME

# ── Frontend Public Vars ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=th
